<Window x:Class="LocatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Locator QR Code Generator" Height="450" Width="650"
        WindowStartupLocation="CenterScreen"
        Background="#e9ecef"
        FontFamily="Segoe UI"
        MinWidth="500" MinHeight="350">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="White" CornerRadius="8" Padding="30" 
                BorderBrush="#343a40" BorderThickness="0,5,0,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="6" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Locator QR Code Generator" FontSize="24" FontWeight="SemiBold" Foreground="#343a40" Grid.Row="0" Margin="0,0,0,5"/>
                <TextBlock Text="Upload the Locator CSV to convert to PDF." FontSize="14" Foreground="#6c757d" Grid.Row="1" Margin="0,0,0,20"/>

                <Grid Grid.Row="2" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding SelectedFilePath, Mode=OneWay}" IsReadOnly="True" 
                             VerticalContentAlignment="Center" Padding="8" Margin="0,0,10,0"
                             BorderBrush="#ccc" BorderThickness="1" Foreground="#495057"/>

                    <Button Command="{Binding BrowseCommand}" Content="Browse CSV" Grid.Column="1" Width="100"/>
                </Grid>

                <StackPanel Grid.Row="3" VerticalAlignment="Top">
                    <Button Command="{Binding GenerateCommand}" Content="Upload &amp; Generate" 
                            Height="45" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,25"/>

                    <TextBlock Text="{Binding ProgressText}" FontWeight="Bold" Foreground="#495057" Margin="0,0,0,10"
                               Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Height="25" Margin="0,0,0,15">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <Button Command="{Binding OpenPdfCommand}" Content="Open QR Locators PDF" 
                            Background="#007bff" Height="40" Width="200" HorizontalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPdfReady}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="4" Text="System tool developed by Jake Panlilio - IT SF1" 
                           HorizontalAlignment="Center" FontSize="12" Foreground="#6c757d" Margin="0,20,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>